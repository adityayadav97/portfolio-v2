              <Copy class="copy-email-icon" size={20} aria-hidden="true" />
              <Check class="copy-email-check" size={20} aria-hidden="true" />
              <span data-copy-label>Copy email</span>
            </button>
            <p class="sr-only" aria-live="polite" data-copy-status></p>
