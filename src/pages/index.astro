        <div class="contact-signal" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="grid-shell contact-grid">
          <div class="contact-status" data-reveal>
            <span class="status-dot" aria-hidden="true"></span>
            Open to Data Engineer roles / Gurgaon or remote
          </div>
          <p class="chapter-label" data-reveal>07 / Contact</p>
          <h2 id="contact-title" data-reveal>Let's move data <span class="kinetic-word">forward.</span></h2>
          <div class="contact-email-wrap" data-reveal>
            <a
              class="contact-email"
              href={gmailComposeUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-external-action
              aria-label={`Compose in Gmail to ${emailAddress} (opens in a new tab)`}
