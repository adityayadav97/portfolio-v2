    description:
      "A local-to-cloud lakehouse that moves retail data through Bronze, Silver, Gold, and dbt marts. Delta MERGE keeps reruns idempotent while automated checks stop bad data before publication.",
    metrics: [
      ["1M+", "records processed"],
      ["15+", "quality checks"],
      ["4", "governed layers"],
    ],
    stack: ["PySpark", "Delta Lake", "dbt", "Airflow", "Docker"],
    repo: "https://github.com/adityayadav97/retail-lakehouse-pipeline",
  },
  {
    number: "03",
    id: "streaming",
    kind: "Streaming systems",
    title: "Real-Time Events Pipeline",
    statement: "Clickstream events become trusted insight in under a minute.",
    description:
      "Kafka feeds Spark Structured Streaming with explicit schemas, checkpointing, watermarks, and bounded micro-batches. Delta provides exactly-once persistence before dbt builds analytics-ready marts.",
    metrics: [
      ["10K+", "events per minute"],
      ["<60s", "event-to-insight"],
      ["10 min", "late-data window"],
    ],
    stack: ["Kafka", "Spark Streaming", "Delta Lake", "dbt", "Airflow"],
    repo: "https://github.com/adityayadav97/realtime-events-pipeline",
  },
  {
    number: "04",
    id: "dashboard",
    kind: "Analytics product",
    title: "Retail Analytics Dashboard",
    statement: "Gold-layer data, shaped for decisions instead of another table dump.",
    description:
      "A Streamlit product surface for revenue KPIs, customer value tiers, quality gates, and pipeline health. The repository is public; deployment remains intentionally marked as not yet live.",
    metrics: [
      ["5", "analysis surfaces"],
      ["4", "quality signals"],
      ["1", "connected lakehouse"],
    ],
    stack: ["Streamlit", "Plotly", "Pandas", "Python"],
    repo: "https://github.com/adityayadav97/retail-analytics-dashboard",
  },
];

const capabilities = [
  {
    label: "Process",
    title: "Distributed compute",
    copy: "Spark, PySpark, Scala, SQL, Databricks",
  },
  {
    label: "Move",
    title: "Batch and streaming",
    copy: "Kafka, Airflow, dbt, StoneBranch, structured streaming",
  },
  {
    label: "Store",
    title: "Cloud data platforms",
    copy: "AWS S3, EMR, EC2, Delta Lake, Hive, Azure",
  },
  {
    label: "Trust",
    title: "Governance and quality",
    copy: "PII compliance, reconciliation, schema controls, observability",
  },
];

const credentials = [
  [
    "Databricks Data Engineer Associate",
    "Databricks, 2026",
    "https://credentials.databricks.com/606adea5-518e-41f4-beb5-d929ce035e10",
  ],
  [
    "Databricks Machine Learning Associate",
    "Databricks, 2026",
    "https://credentials.databricks.com/b47db26e-1464-4a26-bba3-aaf98bc87126",
  ],
  [
    "Claude Certified Architect",
    "Anthropic, 2026",
    "https://verify.skilljar.com/c/zdevrb9toz3j",
  ],
  [
    "AWS Certified Cloud Practitioner",
    "Amazon Web Services, 2025",
    "https://www.credly.com/badges/4e01b90f-ab6b-4937-a70b-2f5a6be5b97c/linked_in_profile",
  ],
  [
    "Azure Fundamentals",
    "Microsoft, 2025",
    "https://learn.microsoft.com/api/credentials/share/en-us/Adityayadav-8366/C5F971221032C906?sharingId=E85349BF47D2DA66",
  ],
  [
    "Azure AI Fundamentals",
    "Microsoft, 2025",
    "https://learn.microsoft.com/en-us/users/adityayadav-8366/credentials/74674ff030b304ce",
  ],
];

const recognition = [
  ["Generative AI Kata", "Winner, EPAM.AI, Jun 2026"],
  ["Architectural Kata", "Winner, EngX India, Apr 2026"],
  ["BAPDM Quarterly Quiz", "Champion across 12 quizzes, 2025"],
  ["EngX Bootcamp", "Top graduate with 90%+ performance, 2024"],
];

const canonical = "https://adityayadav97.github.io/portfolio-v2/";
const socialImage = `${canonical}og.png`;
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Aditya Yadav",
  jobTitle: "Data Engineer",
  worksFor: { "@type": "Organization", name: "EPAM Systems" },
  url: canonical,
  email: "mailto:adityayadav8g@gmail.com",
  sameAs: [
    "https://github.com/adityayadav97",
    "https://www.linkedin.com/in/theadityayadav/",
  ],
  knowsAbout: [
    "Apache Spark",
    "Scala",
    "AWS",
    "Databricks",
    "Data engineering",
    "Data governance",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#070908" />
    <meta
      name="description"
      content="Aditya Yadav is a Data Engineer at EPAM building reliable Spark, Scala, AWS, and Databricks systems at enterprise scale."
    />
    <meta name="author" content="Aditya Yadav" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link
      rel="icon"
      href="https://avatars.githubusercontent.com/u/67759837?v=4"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content="Aditya Yadav - Data Engineer" />
    <meta
      property="og:description"
      content="From raw events to data systems teams can trust."
    />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Aditya Yadav data engineering portfolio and five-stage data pipeline"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Aditya Yadav - Data Engineer" />
    <meta
      name="twitter:description"
      content="From raw events to data systems teams can trust."
    />
    <meta name="twitter:image" content={socialImage} />
    <meta
      name="twitter:image:alt"
      content="Aditya Yadav data engineering portfolio and five-stage data pipeline"
    />
    <title>Aditya Yadav | Data Engineer</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="chromatic-rail" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>
    <div class="scroll-monitor" aria-hidden="true">
      <span class="scroll-monitor-signal"></span>
      <p><b data-scroll-index>00</b><span data-scroll-label>Identity</span></p>
      <i><span data-scroll-meter></span></i>
    </div>
    <div class="ambient-data-field" aria-hidden="true" data-ambient-field>
      <div class="ambient-route ambient-route-left"><i></i><i></i><i></i></div>
      <div class="ambient-route ambient-route-right"><i></i><i></i><i></i></div>
      <span class="ambient-node ambient-node-a"></span>
      <span class="ambient-node ambient-node-b"></span>
      <span class="ambient-node ambient-node-c"></span>
      <span class="ambient-node ambient-node-d"></span>
    </div>

    <header class="site-header" data-header>
      <a class="brand" href="#top" aria-label="Aditya Yadav, back to top">
        <span>AY</span>
        <small>Data systems</small>
      </a>

      <nav class="desktop-nav" aria-label="Primary navigation">
        <a href="#impact">Impact</a>
        <a href="#work">Work</a>
        <a href="#systems">Systems</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>

      <a class="header-cta" href="#contact" aria-label="Let's talk: jump to contact options">
        <Mail size={17} stroke-width={1.8} aria-hidden="true" />
        <span>Let's talk</span>
      </a>

      <button
        class="menu-button"
        type="button"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-menu-button
        title="Open navigation"
      >
        <Menu class="menu-open-icon" size={22} aria-hidden="true" />
        <X class="menu-close-icon" size={22} aria-hidden="true" />
      </button>

      <nav
        class="mobile-nav"
        id="mobile-navigation"
        aria-label="Mobile navigation"
        data-mobile-nav
        hidden
      >
        <a href="#impact">Impact <span>01</span></a>
        <a href="#work">Work <span>02</span></a>
        <a href="#systems">Systems <span>03</span></a>
        <a href="#about">About <span>04</span></a>
        <a href="#contact">Contact <span>05</span></a>
        <a
          href={resumeUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-mobile-resume
          data-external-action
          aria-label="Resume (opens in a new tab)"
        >
          Resume <ArrowUpRight size={18} aria-hidden="true" />
        </a>
      </nav>
    </header>

    <button
      class="flow-control"
      id="flow-toggle"
      type="button"
      aria-pressed="false"
      aria-label="Pause motion"
      title="Pause motion"
    >
      <Pause class="pause-icon" size={18} aria-hidden="true" />
      <Play class="play-icon" size={18} aria-hidden="true" />
      <span data-flow-label>Pause motion</span>
    </button>

    <main id="main-content">
      <section
        class="hero dark-section"
        id="top"
        data-section="top"
        data-motion-section
        data-motion-kind="hero"
        data-scroll-label="Identity"
      >
        <canvas id="data-flow" aria-hidden="true"></canvas>
        <div class="hero-depth-hud" aria-hidden="true">
          <div class="hero-depth-readout">
            <span>DATA PLANE / RUN 042</span>
            <b><i></i> LIVE</b>
          </div>
          <div class="hero-depth-axis">
            <span><small>INPUT</small> 3 FEEDS</span>
            <span><small>FLOW</small> 10.4K/MIN</span>
            <span><small>QUALITY</small> 15/15</span>
          </div>
          <i class="hero-depth-shard hero-depth-shard-a"></i>
          <i class="hero-depth-shard hero-depth-shard-b"></i>
          <i class="hero-depth-shard hero-depth-shard-c"></i>
        </div>
        <div class="hero-grid grid-shell">
          <div class="hero-kicker" data-reveal>
            <span class="status-dot" aria-hidden="true"></span>
            Data Engineer at EPAM / Gurgaon, India
          </div>

          <div class="hero-copy" data-reveal="hero">
            <p class="chapter-label">00 / Identity</p>
            <h1>
              <span>Aditya</span>
              <span>Yadav</span>
            </h1>
            <p class="hero-thesis">
              I turn complex data into systems teams can <em>trust.</em>
            </p>
            <p class="hero-summary">
              Spark, Scala, AWS, and Databricks for production data platforms
              where scale matters and correctness cannot be negotiated.
            </p>
            <div class="hero-actions">
              <a class="button button-solid" href="#impact">
                <span>Explore the impact</span>
                <ArrowDownRight size={19} aria-hidden="true" />
              </a>
              <a
                class="button button-ghost"
                href={resumeUrl}
                target="_blank"
                rel="noopener noreferrer"
                data-external-action
                aria-label="View resume (opens in a new tab)"
              >
                <FileText size={18} aria-hidden="true" />
                <span>View resume</span>
              </a>
            </div>
          </div>

          <div class="hero-color-key" aria-hidden="true">
            <span>RAW</span>
            <span>MOVE</span>
            <span>MODEL</span>
            <span>TRUST</span>
          </div>

          <div class="hero-telemetry" aria-label="Selected engineering metrics">
            <p><span></span>Live reliability</p>
            <div>
              <span>Throughput</span>
              <strong data-flow-throughput>10.4k/min</strong>
            </div>
            <div>
              <span>Quality gate</span>
              <strong>15/15 pass</strong>
            </div>
            <div>
              <span>Delivery</span>
              <strong>Exactly once</strong>
            </div>
          </div>
        </div>
      </section>

      <section
        class="proof-band"
        id="impact"
        data-section="impact"
        data-scroll-label="Production evidence"
        aria-labelledby="impact-label"
      >
        <div class="grid-shell proof-grid">
          <p class="proof-intro" id="impact-label" data-menu-focus>Production evidence</p>
          <div class="proof-stat">
            <strong data-count="200" data-suffix="+">200+</strong>
            <span>tables migrated</span>
          </div>
          <div class="proof-stat">
            <strong data-count="6" data-suffix="+">6+</strong>
            <span>production pipelines</span>
          </div>
          <div class="proof-stat">
            <strong data-count="0">0</strong>
            <span>data loss</span>
          </div>
          <div class="proof-stat">
            <strong data-count="3">3</strong>
            <span>Fortune 500 clients</span>
          </div>
        </div>
      </section>

      <section
        class="manifesto paper-section"
        data-section="impact"
        data-motion-section
        data-motion-kind="manifesto"
        data-scroll-label="Point of view"
      >
        <div class="grid-shell manifesto-grid">
          <p class="chapter-label dark-label" data-reveal>01 / Point of view</p>
          <div class="manifesto-copy" data-reveal>
            <h2>
              Data is not valuable when it lands. It is valuable when the next
              person can <span class="kinetic-word">rely on it.</span>
            </h2>
            <p>
              My work sits between raw systems and real decisions: migrating
              legacy estates, designing quality gates, resolving production
              failures, and making data platforms easier to operate at scale.
            </p>
          </div>
          <figure class="portrait" data-portrait data-reveal>
            <img
              src="https://avatars.githubusercontent.com/u/67759837?v=4"
              alt="Portrait of Aditya Yadav"
              width="460"
              height="460"
              loading="lazy"
            />
            <span class="portrait-scan" aria-hidden="true"></span>
            <figcaption>
              <span>Aditya Yadav</span>
              <span>Data Engineer / Builder</span>
            </figcaption>
          </figure>
        </div>
      </section>

      <section
        class="experience paper-section"
        data-section="impact"
        data-motion-section
        data-motion-kind="experience"
        data-scroll-label="Production trail"
      >
        <div class="experience-shell grid-shell">
          <div class="section-heading" data-reveal="heading">
            <p class="chapter-label dark-label">02 / Production trail</p>
            <h2>Work measured in migrations, reliability, and people unblocked.</h2>
            <div class="experience-route" aria-hidden="true">
              <span>Now</span><i></i><span>Migrate</span><i></i><span>Tune</span><i></i><span>Build</span>
            </div>
          </div>

          <div class="experience-list">
            {
              experiences.map((item, index) => (
                <article
                  class="experience-row"
                  data-reveal
                  data-experience-row
                  data-row-index={String(index + 1).padStart(2, "0")}
                >
                  <p class="row-index">{String(index + 1).padStart(2, "0")}</p>
                  <p class="row-period">{item.period}</p>
                  <div class="row-role">
                    <h3>{item.role}</h3>
                    <p>{item.client}</p>
                    <small>{item.context}</small>
                  </div>
                  <div class="row-impact">
                    <p>{item.impact}</p>
                    <ul aria-label={`${item.client} impact metrics`}>
                      {item.metrics.map((metric) => <li>{metric}</li>)}
                    </ul>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="work-intro dark-section"
        id="work"
        data-section="work"
        data-motion-section
        data-motion-kind="work-intro"
        data-scroll-label="Selected systems"
      >
        <div class="grid-shell section-heading light-heading" data-reveal>
          <p class="chapter-label">03 / Selected systems</p>
          <h2>Four builds. Four different ways to make data useful.</h2>
          <p class="section-summary">
            Award-winning AI leads the set. Every project exposes the architecture,
            the constraint, and the proof behind the interface.
          </p>
        </div>
      </section>

      <div
        class="signal-ribbon"
        aria-hidden="true"
        data-motion-section
        data-motion-kind="signal-ribbon"
      >
        <div class="signal-ribbon-track">
          <span>RAW SIGNAL</span><i></i><span>REPLAY</span><i></i><span>OBSERVE</span><i></i><span>QUALITY</span><i></i><span>TRUST</span><i></i>
          <span>RAW SIGNAL</span><i></i><span>REPLAY</span><i></i><span>OBSERVE</span><i></i><span>QUALITY</span><i></i><span>TRUST</span><i></i>
        </div>
      </div>

      {
        projects.map((project, projectIndex) => (
          <section
            class:list={["project-chapter", `project-${project.id}`]}
            id={project.id}
            data-section="work"
            data-motion-section
            data-motion-kind="project"
            data-scroll-label={project.title}
            data-project-index={project.number}
          >
            <div class="grid-shell project-grid">
              <div class="project-meta" data-reveal>
                <p>{project.number}</p>
                <span>{project.kind}</span>
                {project.featured && (
                  <div class="featured-project-status">
                    <strong class="featured-project-badge">
                      <Sparkles size={15} aria-hidden="true" /> 2026 Gen-AI Kata Winner
                    </strong>
                    <span class="featured-live-state"><i aria-hidden="true"></i> Live product</span>
                  </div>
                )}
              </div>

              <div class="project-copy" data-reveal>
                <h3>
                  {project.id === "benchbuddy" ? (
                    <>BenchBuddy <span class="kinetic-word">AI</span></>
                  ) : project.title}
                </h3>
                <p class="project-statement">{project.statement}</p>
                <p class="project-description">{project.description}</p>
                <ul class="stack-list" aria-label={`${project.title} technology stack`}>
                  {project.stack.map((item) => <li>{item}</li>)}
                </ul>
                <div class="project-links">
                  {project.live && (
                    <a
                      class="project-action project-action-live"
                      href={project.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Launch ${project.title} live experience (opens in a new tab)`}
                    >
                      <Sparkles size={18} aria-hidden="true" />
                      {project.id === "benchbuddy" ? "Try BenchBuddy AI" : "Launch live experience"}
                      <ExternalLink size={16} aria-hidden="true" />
                    </a>
                  )}
                  <a
                    class="project-action project-action-source"
                    href={project.repo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Inspect ${project.title} source code (opens in a new tab)`}
                  >
                    <CodeXml size={18} aria-hidden="true" />
                    {
                      project.id === "benchbuddy"
                        ? "Review source & tests"
                        : project.id === "dashboard"
                          ? "View dashboard source"
                          : "View pipeline source"
                    }
                    <ArrowUpRight size={16} aria-hidden="true" />
                  </a>
                </div>
              </div>

              <div
                class:list={["project-visual", `visual-${project.id}`]}
                role="img"
                aria-label={
                  project.id === "lakehouse"
                    ? "Diagram of data moving from raw sources through Bronze, Silver, Gold, and analytics marts"
                    : project.id === "streaming"
                      ? "Diagram of events moving through Kafka, Spark Streaming, Delta Lake, and dbt"
                      : project.id === "benchbuddy"
                        ? "Grounded assistant response showing confidence, category, and escalation status"
                        : "Analytics interface showing revenue, quality, and pipeline-health signals"
                }
                data-reveal
                data-tilt-surface
              >
                <div class="visual-chrome" aria-hidden="true">
                  <span>{project.featured ? "LIVE PRODUCT" : "SCROLL PLAYBACK"}</span>
                  <i></i>
                  <b>{project.number}</b>
                </div>
                {project.id === "lakehouse" && (
                  <div class="lakehouse-flow" aria-hidden="true">
                    <aside class="flow-runline">
                      <span><i></i> RUN 042</span>
                      <span>1.05M ROWS</span>
                      <span>0 REJECTED</span>
                    </aside>
                    <div class="flow-node raw-node"><span>RAW</span><b>1,052,000</b></div>
                    <i></i>
                    <div class="flow-node bronze-node"><span>BRONZE</span><b>INGEST</b></div>
                    <i></i>
                    <div class="flow-node silver-node"><span>SILVER</span><b>CLEAN</b></div>
                    <i></i>
                    <div class="flow-node gold-node"><span>GOLD</span><b>TRUSTED</b></div>
                    <i></i>
                    <div class="flow-node marts-node"><span>MARTS</span><b>READY</b></div>
                  </div>
                )}

                {project.id === "streaming" && (
                  <div class="stream-flow" aria-hidden="true">
                    <div class="stream-source">
                      <span>EVENTS</span>
                      <b>10,482 / MIN</b>
                    </div>
                    <div class="stream-line"><i></i><i></i><i></i><i></i></div>
                    <div class="stream-processors">
                      <span>KAFKA</span><span>SPARK</span><span>DELTA</span><span>DBT</span>
                    </div>
                    <div class="stream-status">
                      <Check size={18} aria-hidden="true" /> EXACTLY ONCE
                    </div>
                  </div>
                )}

                {project.id === "benchbuddy" && (
                  <div class="assistant-ui" aria-hidden="true">
                    <div class="assistant-topline">
                      <span>BENCHBUDDY / GROUNDED MODE</span><b>LIVE</b>
                    </div>
                    <div class="assistant-retrieval">
                      <span>KNOWLEDGE</span><i></i><span>RETRIEVE</span><i></i><span>ANSWER</span>
                    </div>
                    <p>Can I claim an AWS certification reimbursement?</p>
                    <div class="assistant-answer">
                      <span>GROUNDED RESPONSE / 2 APPROVED SOURCES</span>
