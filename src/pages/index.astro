                      <div class="assistant-confidence"><i></i></div>
                    </div>
                    <div class="assistant-signals">
                      <span>Confidence <b>95%</b></span>
                      <span>Evidence <b>Policy 4.2</b></span>
                      <span>Status <b>Answered</b></span>
                      <span>Escalate <b>Below 70%</b></span>
                    </div>
                  </div>
                )}

                {project.id === "dashboard" && (
                  <div class="dashboard-ui" aria-hidden="true">
                    <div class="dashboard-head">
                      <span>GOLD / EXECUTIVE VIEW</span>
                      <b>QUALITY PASS</b>
                    </div>
                    <div class="dashboard-kpis">
                      <span><small>Revenue</small><b>$4.82M</b></span>
                      <span><small>Orders</small><b>128K</b></span>
                      <span><small>Freshness</small><b>2m</b></span>
                    </div>
                    <div class="dashboard-chart">
                      <div class="dashboard-bars">
                        {[36, 62, 44, 78, 58, 88, 72, 94].map((height) => (
                          <i style={`--bar:${height}%`}></i>
                        ))}
                      </div>
                      <svg
                        class="dashboard-trend"
                        viewBox="0 0 640 120"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                        focusable="false"
                      >
                        <polyline points="0,92 80,76 160,83 240,52 320,61 400,32 480,42 560,18 640,24" />
                      </svg>
                      <span class="dashboard-playhead"></span>
                    </div>
                    <div class="dashboard-live-row">
                      <span><Activity size={15} aria-hidden="true" /> Scroll playback</span>
                      <b>00:02</b>
                    </div>
                    <div class="dashboard-foot">
                      <span>Bronze</span><span>Silver</span><span>Gold</span><span>Marts</span>
                    </div>
                  </div>
                )}
              </div>

              <div class="project-metrics" data-reveal>
                {project.metrics.map(([value, label]) => (
                  <div>
                    <strong>{value}</strong>
                    <span>{label}</span>
                  </div>
                ))}
              </div>

              <p class="project-count" aria-hidden="true">
                {String(projectIndex + 1).padStart(2, "0")} / {String(projects.length).padStart(2, "0")}
              </p>
            </div>
          </section>
        ))
      }

      <section
        class="systems signal-section"
        id="systems"
        data-section="systems"
        data-motion-section
        data-motion-kind="systems"
        data-scroll-label="System ownership"
        data-bloom-section
      >
        <div class="grid-shell systems-grid">
          <div class="systems-heading">
            <p class="chapter-label dark-label" data-reveal>04 / System ownership</p>
            <h2 data-reveal="heading">From ingestion to the trust layer.</h2>
            <p data-reveal>
              The tools change. The responsibility stays the same: move data
              predictably, make failures observable, and leave a system easier
              to operate than it was before.
            </p>

            <div class="bloom-stage" data-bloom-stage data-reveal data-tilt-surface>
              <canvas id="trust-bloom" aria-hidden="true"></canvas>
              <div class="bloom-telemetry" aria-hidden="true">
                <span><i></i> 4 LAYERS</span>
                <b>15 GATES</b>
              </div>
              <div class="bloom-core-copy" aria-hidden="true">
                <span>TRUST LAYER</span>
                <strong>LIVE</strong>
              </div>
              <div class="bloom-legend" aria-hidden="true">
                <span>Compute</span><span>Move</span><span>Store</span><span>Trust</span>
              </div>
            </div>
          </div>

          <div class="capability-list">
            {
              capabilities.map((capability, index) => (
                <article class="capability-row" data-reveal data-capability-index={index}>
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <p>{capability.label}</p>
                  <h3>{capability.title}</h3>
                  <small>{capability.copy}</small>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="credentials dark-section"
        data-section="systems"
        data-motion-section
        data-motion-kind="credentials"
        data-scroll-label="Verified signal"
      >
        <div class="grid-shell credentials-grid">
          <div class="credentials-heading" data-reveal>
            <p class="chapter-label">05 / Verified signal</p>
            <h2>Credentials backed by shipped work.</h2>
            <p>Six active credentials plus the competitive wins that mattered most.</p>
          </div>

          <div class="credential-list" aria-label="Professional credentials">
            {
              credentials.map(([title, issuer, url], index) => (
                <a href={url} target="_blank" rel="noreferrer" data-reveal>
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <strong>{title}</strong>
                  <small>{issuer}</small>
                  <ArrowUpRight size={18} aria-hidden="true" />
                </a>
              ))
            }
          </div>

          <div class="recognition-list" aria-label="Awards and recognition">
            {
              recognition.map(([title, detail]) => (
                <article data-reveal>
                  <Award size={21} aria-hidden="true" />
                  <div>
                    <h3>{title}</h3>
                    <p>{detail}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        class="about paper-section"
        id="about"
        data-section="about"
        data-motion-section
        data-motion-kind="about"
        data-scroll-label="About"
      >
        <div class="grid-shell about-grid">
          <p class="chapter-label dark-label" data-reveal>06 / About</p>
          <div class="about-copy" data-reveal>
            <h2>Engineer the system. Explain the decision. <span class="kinetic-word">Own the outcome.</span></h2>
            <p>
              I am a Computer Science graduate specializing in Big Data
              Analytics, now building and migrating enterprise data systems at
              EPAM. I care about calm production rollouts, visible quality, and
              automation that removes repetitive work instead of hiding it.
            </p>
          </div>
          <div class="principles" data-reveal>
            <article>
              <Database size={22} aria-hidden="true" />
              <h3>Design for replay</h3>
              <p>Idempotent paths make recovery a normal operation.</p>
            </article>
            <article>
              <ShieldCheck size={22} aria-hidden="true" />
              <h3>Trust is engineered</h3>
              <p>Quality gates belong inside the pipeline, not after it.</p>
            </article>
            <article>
              <Sparkles size={22} aria-hidden="true" />
              <h3>Automate the drag</h3>
              <p>Remove manual steps where judgement is not required.</p>
            </article>
          </div>
        </div>
      </section>

      <section
        class="contact dark-section"
        id="contact"
        data-section="contact"
        data-motion-section
        data-motion-kind="contact"
        data-scroll-label="Contact"
        aria-labelledby="contact-title"
