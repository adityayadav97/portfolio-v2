              <span class="contact-link-icon"><CodeXml size={27} aria-hidden="true" /></span>
              <span><strong>GitHub</strong><small>Systems, code, and experiments</small></span>
              <ArrowUpRight class="contact-link-arrow" size={22} aria-hidden="true" />
