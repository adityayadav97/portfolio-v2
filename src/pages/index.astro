              <span class="contact-link-icon"><FileText size={27} aria-hidden="true" /></span>
              <span><strong>Resume</strong><small>Impact, projects, and credentials</small></span>
              <ArrowUpRight class="contact-link-arrow" size={22} aria-hidden="true" />
