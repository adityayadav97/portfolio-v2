              <span class="contact-email-main">
                <small>Compose in Gmail</small>
                <strong>{emailUser}<wbr />@{emailDomain}</strong>
              </span>
              <span class="contact-email-action">
                <span>Start conversation</span><ArrowUpRight aria-hidden="true" />
              </span>
            </a>
            <button
              class="copy-email"
              type="button"
              data-copy-email
              data-email={emailAddress}
              aria-label={`Copy ${emailAddress}`}
