---
import "@fontsource-variable/space-grotesk";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/600.css";
import "@fontsource/instrument-serif";
import "../styles/global.css";
import {
  Activity,
  ArrowUp,
  ArrowDownRight,
  ArrowUpRight,
  Award,
  Check,
  CodeXml,
  ContactRound,
  Copy,
  Database,
  ExternalLink,
  FileText,
  Mail,
  Menu,
  Pause,
  Play,
  ShieldCheck,
  Sparkles,
  X,
} from "@lucide/astro";

const resumeUrl =
  "https://drive.google.com/file/d/1mhOFp3oGO1Zi1V76GKXMZral6wfICptW/view?usp=sharing";
const emailAddress = "adityayadav8g@gmail.com";
const gmailComposeUrl =
  `https://mail.google.com/mail/?view=cm&fs=1&to=${emailAddress}&su=${encodeURIComponent("Data engineering opportunity")}`;
const [emailUser, emailDomain] = emailAddress.split("@");

const experiences = [
